# Server
PORT=3040
DRAIN_TIMEOUT=300

# Twilio (Voice)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
# an ngrok public URL can be used as well which can be configured at https://dashboard.ngrok.com/domains
TWILIO_PUBLIC_URL=https://your-public-url.example.com

# Speech-to-Text (Deepgram Flux)
DEEPGRAM_API_KEY=your_deepgram_api_key

# LLM
LLM_PROVIDER=groq

# Groq API
GROQ_API_KEY=your_groq_api_key

# OpenAI API
OPENAI_API_KEY=your_openai_api_key

# Local LLM
LOCAL_LLM_BASE_URL=your_local_llm_ip
LOCAL_LLM_API_KEY=your_local_llm_api_key

# LLM from selected provider
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
